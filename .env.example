# Giphy GIF search (used by the canvas "+" sticker sheet).
# Get a free key (no credit card needed): https://developers.giphy.com/dashboard/
# Copy this file to .env and fill in your key. EXPO_PUBLIC_ vars are inlined
# into the app bundle at build time, so this key is visible to end users —
# the same way Giphy's own client-side examples expect it to be used.
EXPO_PUBLIC_GIPHY_API_KEY=
